{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AncientRomanceDialoguePatterns",
  "description": "古风言情对白模式库 — 古风对白的规则、示例和避坑指南",
  "version": "1.0.0",

  "coreRules": {
    "formalityLevels": {
      "description": "古风对白不是文言文，也不是现代口语，是介于两者之间的'古白话'",
      "levels": {
        "formal": {
          "label": "正式场合",
          "usage": "朝堂、宴会、见长辈、初次见面",
          "features": ["用'您'", "称呼用全名或头衔", "句子完整", "不用省略号"],
          "example": "臣女沈昭宁，见过侯爷。"
        },
        "semi-formal": {
          "label": "半正式场合",
          "usage": "同辈之间、主仆日常、夫妻相处",
          "features": ["用'你'", "称呼用名字或排行", "可以有省略", "偶有口语"],
          "example": "姑娘，老太太那边传话了。"
        },
        "casual": {
          "label": "私下场合",
          "usage": "亲密关系、独处、私下商议",
          "features": ["口语化", "有打断", "有省略", "有方言"],
          "example": "你又把柴火弄湿了？昨晚那么大的雨不知道收？"
        }
      }
    },

    "speechTags": {
      "description": "不要只用'说'，也不要每个对白都加标签",
      "diverseVerbs": ["道", "问", "答", "应", "笑", "叹", "哼", "骂", "嘟囔", "嘀咕", "低语", "嚷", "吼", "啐", "嗤"],
      "noTagExamples": [
        "她把茶碗放下。\"让她进来。\"",
        "春芜眨眨眼：\"在呢，搁在食盒里没动。\""
      ],
      "actionInsteadOfTag": [
        "\"别哭。\"她从春芜身边走过去。",
        "\"不用请大夫。\"她走到衣架前，拽下那件青碧色的褙子。"
      ]
    },

    "subtext": {
      "description": "角色说的话≠角色想的话。对白要有潜台词。",
      "examples": [
        {
          "surface": "\"替我谢过二婶。\"",
          "subtext": "我知道二婶在试探我，但我装不知道",
          "context": "收下不喜欢的礼物时"
        },
        {
          "surface": "\"姑娘记性好。\"",
          "subtext": "你怎么突然问这个？你是不是知道了什么？",
          "context": "被问到不该知道的事时"
        },
        {
          "surface": "\"没事。\"",
          "subtext": "有事，但我不说",
          "context": "角色嘴上说没事但手在发抖时"
        }
      ]
    },

    "interruptions": {
      "description": "真实的对话有打断、犹豫、未说完的话",
      "techniques": [
        "用破折号表示被打断：\"我其实想说——\"",
        "用省略号表示犹豫：\"那个……算了。\"",
        "用动作打断对白：\"她刚要开口，门被推开了。\"",
        "用沉默代替回答：他问了三遍，她一个字也没说。"
      ]
    }
  },

  "periodAppropriate": {
    "addresses": {
      "self-reference": {
        "female-humble": ["臣女", "民女", "奴家", "妾身", "婢子"],
        "female-casual": ["我", "人家"],
        "male-humble": ["臣", "草民", "在下", "小人"],
        "male-casual": ["我", "本公子", "爷"],
        "servant": ["奴婢", "奴才", "小的", "婢子"]
      },
      "addressing-others": {
        "emperor": ["皇上", "陛下", "圣上"],
        "elder-female": ["老太太", "老夫人", "太太", "夫人", "婶娘", "伯母"],
        "elder-male": ["老爷", "侯爷", "大人", "伯父", "叔父"],
        "peer-female": ["姑娘", "小姐", "姐姐", "妹妹", "X娘"],
        "peer-male": ["公子", "少爷", "爷", "兄台", "X郎"],
        "servant": ["嬷嬷", "妈妈", "姐姐", "X家的"]
      }
    },

    "commonExpressions": {
      "agreement": ["是", "嗯", "也好", "依你", "听你的", "就依姑娘所言"],
      "refusal": ["不可", "不妥", "使不得", "这怎么使得", "恕难从命"],
      "surprise": ["当真？", "此话怎讲？", "你……", "这……"],
      "anger": ["放肆", "大胆", "你敢", "好大的胆子"],
      "farewell": ["告辞", "先行一步", "改日再叙", "慢走", "好走"],
      "gratitude": ["多谢", "有劳", "费心了", "承蒙照顾"],
      "apology": ["失礼了", "得罪", "恕罪", "冒犯了"]
    },

    "taboos": {
      "description": "古风对白中绝对不能出现的现代词汇",
      "words": [
        "OK", "好的", "没问题", "收到", "了解",
        "随便", "无所谓", "无所谓啦",
        "加油", "努力", "坚持",
        "崩溃", "无语", "尴尬",
        "老公", "老婆", "亲爱的",
        "拜拜", "再见", "下次见",
        "不好意思", "抱歉", "对不起"
      ],
      "replacements": {
        "好的": "好 / 嗯 / 知道了 / 晓得了",
        "没问题": "无妨 / 不碍事 / 好说",
        "不好意思": "失礼了 / 冒犯了",
        "对不起": "对不住 / 是我的不是",
        "再见": "告辞 / 先行一步 / 改日再叙"
      }
    }
  },

  "dialogueRhythm": {
    "description": "对白的节奏控制",
    "rules": [
      "连续三句纯对白必须插入动作或环境描写",
      "长对白（超过30字）前后要有停顿或动作",
      "紧张场景对白要短——一个词、半句话",
      "舒缓场景对白可以长——但不要超过50字",
      "对白之间可以插入叙述者的评论（但要克制）"
    ],
    "examples": {
      "tense": {
        "description": "紧张场景的对白",
        "example": "\"走。\"\n\"去哪儿？\"\n\"别问。\""
      },
      "relaxed": {
        "description": "舒缓场景的对白",
        "example": "春芜端着茶进来，搁在桌上。\"姑娘，老太太那边说了，明儿个让您过去请安。\"\n\"嗯。\"沈昭宁头也没抬，手里还攥着那块云锦。\n\"还说让您穿那件新做的衣裳。\"\n\"知道了。\""
      }
    }
  }
}
